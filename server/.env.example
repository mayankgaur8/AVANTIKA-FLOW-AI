# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/avantika_flow

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Email verification
VERIFICATION_TOKEN_TTL_MINUTES=60
RESEND_VERIFICATION_COOLDOWN_SECONDS=60

# Frontend origin + CORS
FRONTEND_URL=http://localhost:5175
CLIENT_ORIGIN=http://localhost:5175
CORS_ORIGIN=http://localhost:5175

# Admin approval control
ADMIN_EMAIL=admin@avantikaflow.ai
ADMIN_SECRET=replace-with-strong-admin-secret
SERVER_BASE_URL=http://localhost:3001

# Sales + notifications (optional)
SALES_INBOX_EMAIL=sales@avantikaflow.ai
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ENABLE_AUTO_REPLY=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
